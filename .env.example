# URL сайта для SEO, OpenGraph и sitemap
NEXT_PUBLIC_SITE_URL=https://lidgen.ru

# Яндекс.Метрика: номер счётчика (только цифры). Вебвизор включён в коде.
# Создайте счётчик на https://metrika.yandex.ru и вставьте ID сюда.
NEXT_PUBLIC_YM_COUNTER_ID=

# A/B тест заголовка: 1 | 2 | 3 | 4
# 1 = "Сколько денег вы уже слили на рекламу?"
# 2 = "Показы есть. Клиентов нет?"
# 3 = "Люди доверяют людям. Не рекламе."
# 4 = "Зарабатывайте на статусах в соцсетях" (для кампаний на исполнителей)
NEXT_PUBLIC_HERO_VARIANT=1

# A/B тест липкой плашки: free | task | earn
NEXT_PUBLIC_STICKY_VARIANT=free
